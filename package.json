{
  "name": "llm-debate",
  "version": "1.0.0",
  "description": "LLM Debate Arena - Two models debate, a third judges",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server/index.js",
    "dev": "node dist/server/index.js",
    "mock": "node dist/server/mock/index.js",
    "validate": "node dist/server/mock/index.js",
    "build": "npm run build:server && npm run build:client && npm run build:tts",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "esbuild client/index.ts --bundle --outfile=public/js/bundle.js --minify",
    "build:tts": "esbuild client/tts/worker.ts --bundle --outfile=public/js/tts-worker.js --format=iife --minify",
    "build:ts": "npm run build:server && npm run build:client",
    "start:ts": "node dist/server/index.js",
    "dev:server": "tsx watch server/index.ts",
    "dev:mock": "tsx watch mock/index.ts",
    "mock:ts": "node dist/mock/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.client.json"
  },
  "dependencies": {
    "express": "^4.21.0",
    "openai": "^4.70.0",
    "cors": "^2.8.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0"
  }
}
