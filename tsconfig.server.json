{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/server",
    "rootDir": "."
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "mock/**/*.ts"
  ],
  "exclude": [
    "client/**/*.ts",
    "node_modules",
    "dist"
  ]
}
